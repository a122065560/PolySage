# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
app/dist/
app/build/
*.spec.bak
# PyInstaller 自动生成的 spec（PolySage.spec 是 Windows CI 用的，需要保留）
聚慧.spec

# 虚拟环境
venv/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# 日志
*.log

# 用户数据（不应提交）
*.pfx
*.key
.env
secrets/

# Playwright
playwright-report/
test-results/

# 构建产物（build/ 目录中的 .app .dmg .exe 不提交）
build/*.dmg
build/*.exe
build/*.msi
build/聚慧.app
# 项目根目录下的 .app（构建意外输出到根目录时忽略）
/聚慧.app
/聚慧-*.dmg

# 临时文件
tmp/
temp/
